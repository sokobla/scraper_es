# scrapper_spain - Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ====================================
# Database Configuration
# ====================================
DATABASE_URL=postgresql://scrapper:secure_password@localhost:5432/scrapper_db

# ====================================
# Logging Configuration
# ====================================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# DEBUG = verbose (development)
# INFO = normal (production)

# ====================================
# Scraper Configuration
# ====================================
SCRAPER_HEADLESS=true
# true = run browser in headless mode (no GUI, faster)
# false = show browser window (debugging)

SCRAPER_MAX_PAGES=3
# Maximum number of pages to scrape per category
# Higher = more data but longer execution time

SCRAPER_RATE_LIMIT_DELAY=2
# Delay in seconds between HTTP requests
# Higher = more "polite" to target website, less likely to be blocked
# Minimum recommended: 2 seconds

SCRAPER_TIMEOUT_SECONDS=30
# Timeout in seconds for page loads
# Increase if target website is slow

# ====================================
# Proxy Configuration (Optional)
# ====================================
# Uncomment if scraping through proxy
# HTTP_PROXY=http://proxy_ip:proxy_port
# HTTPS_PROXY=http://proxy_ip:proxy_port
# NO_PROXY=localhost,127.0.0.1

# ====================================
# Docker Configuration (if using docker-compose)
# ====================================
DB_USER=scrapper
DB_PASSWORD=secure_password
DB_NAME=scrapper_db

# ====================================
# Optional: Monitoring & Alerts
# ====================================
# SENTRY_DSN=https://...@sentry.io/...
# SLACK_WEBHOOK_URL=https://hooks.slack.com/...
